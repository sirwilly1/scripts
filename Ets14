Use this plan.

1) Run a lightweight IQ TCP streamer on the E320

Save this on the E320 as e320_iq_stream.py:

#!/usr/bin/env python3
import argparse
import socket
import struct
import sys
import time
import numpy as np
import uhd
def make_streamer(
    args_str: str,
    rate: float,
    freq: float,
    gain: float,
    antenna: str,
    bandwidth: float | None,
):
    usrp = uhd.usrp.MultiUSRP(args_str)
    usrp.set_rx_rate(rate)
    usrp.set_rx_freq(uhd.types.TuneRequest(freq))
    usrp.set_rx_gain(gain)
    if antenna:
        usrp.set_rx_antenna(antenna)
    if bandwidth is not None and bandwidth > 0:
        usrp.set_rx_bandwidth(bandwidth)
    st_args = uhd.usrp.StreamArgs("fc32", "sc16")
    st_args.channels = [0]
    rx_streamer = usrp.get_rx_stream(st_args)
    return usrp, rx_streamer
def serve_forever(
    bind_host: str,
    bind_port: int,
    rx_streamer,
    max_samps_per_packet: int,
):
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind((bind_host, bind_port))
    server.listen(1)
    print(f"[E320] Listening on {bind_host}:{bind_port}", flush=True)
    while True:
        conn, addr = server.accept()
        print(f"[E320] Client connected: {addr}", flush=True)
        try:
            conn.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            md = uhd.types.RXMetadata()
            recv_buffer = np.zeros((1, max_samps_per_packet), dtype=np.complex64)
            stream_cmd = uhd.types.StreamCMD(uhd.types.StreamMode.start_cont)
            stream_cmd.stream_now = True
            rx_streamer.issue_stream_cmd(stream_cmd)
            try:
                while True:
                    num_rx = rx_streamer.recv(recv_buffer, md, timeout=1.0)
                    if md.error_code != uhd.types.RXMetadataErrorCode.none:
                        if md.error_code == uhd.types.RXMetadataErrorCode.timeout:
                            continue
                        print(f"[E320] RX metadata error: {md.strerror()}", flush=True)
                        break
                    if num_rx <= 0:
                        continue
                    iq = recv_buffer[0, :num_rx]
                    # Convert fc32 -> interleaved int16 IQ for easy GNU Radio ingest
                    i = np.clip(np.real(iq) * 32767.0, -32768, 32767).astype(np.int16)
                    q = np.clip(np.imag(iq) * 32767.0, -32768, 32767).astype(np.int16)
                    interleaved = np.empty(num_rx * 2, dtype=np.int16)
                    interleaved[0::2] = i
                    interleaved[1::2] = q
                    conn.sendall(interleaved.tobytes())
            finally:
                stop_cmd = uhd.types.StreamCMD(uhd.types.StreamMode.stop_cont)
                rx_streamer.issue_stream_cmd(stop_cmd)
        except (BrokenPipeError, ConnectionResetError):
            print("[E320] Client disconnected", flush=True)
        except Exception as e:
            print(f"[E320] Stream error: {e}", flush=True)
        finally:
            try:
                conn.close()
            except Exception:
                pass
def parse_args():
    p = argparse.ArgumentParser(description="E320 IQ TCP streamer")
    p.add_argument("--addr", default="addr=127.0.0.1", help="UHD device args")
    p.add_argument("--rate", type=float, default=250e3, help="Sample rate")
    p.add_argument("--freq", type=float, required=True, help="Center frequency in Hz")
    p.add_argument("--gain", type=float, default=20.0, help="RX gain in dB")
    p.add_argument("--antenna", default="", help="RX antenna, e.g. RX2")
    p.add_argument("--bandwidth", type=float, default=0.0, help="RX bandwidth in Hz")
    p.add_argument("--host", default="0.0.0.0", help="Bind address")
    p.add_argument("--port", type=int, default=5000, help="TCP port")
    p.add_argument("--spp", type=int, default=4096, help="Samples per packet")
    return p.parse_args()
def main():
    args = parse_args()
    _, rx_streamer = make_streamer(
        args.addr,
        args.rate,
        args.freq,
        args.gain,
        args.antenna,
        args.bandwidth if args.bandwidth > 0 else None,
    )
    serve_forever(args.host, args.port, rx_streamer, args.spp)
if __name__ == "__main__":
    main()

Make it executable:

chmod +x e320_iq_stream.py

Run it on the E320 like this:

python3 e320_iq_stream.py --freq 100e6 --rate 250e3 --gain 20 --port 5000

If you know the antenna you want, for example:

python3 e320_iq_stream.py --freq 100e6 --rate 250e3 --gain 20 --antenna RX2 --port 5000

