Fix: match EVERYTHING and inspect it

Replace your script with this:

#!/usr/bin/expect -f
set timeout 120
exp_internal 1

set pass "YOUR_PASSWORD"
spawn ssh -tt -o StrictHostKeyChecking=accept-new $user@$host
# Print everything that comes in
log_user 1
expect {
    -re ".*" {
        puts "MATCHED: $expect_out(buffer)"
        if {[string match -nocase "*password*" $expect_out(buffer)]} {
            send -- "$pass\r"
        }
        if {[string match -nocase "*agree*" $expect_out(buffer)]} {
            send -- "y\r"
        }
        exp_continue
    }
    timeout {
        puts "TIMEOUT - nothing matched"
        exit 1
    }
}
interact

