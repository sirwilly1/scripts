def create_example_files(args):
    Path(args.local_watch_dir).mkdir(parents=True, exist_ok=True)
    Path(args.remote_watch_dir).mkdir(parents=True, exist_ok=True)
    site2_path = Path(args.site2_json)
    site3_path = Path(args.site3_json)
    if not site2_path.exists():
        site2_path.write_text(json.dumps({
            "site_name": "Site 2",
            "location": "South Valley",
            "center_frequency_hz": 91500000,
            "sample_rate_hz": 250000,
            "gain_db": 25,
            "antenna": "Yagi 8-element",
            "rf_frontend": "E320",
            "reference": "GPSDO",
            "notes": "Backup site",
            "enabled": True,
        }, indent=2))
    if not site3_path.exists():
        site3_path.write_text(json.dumps({
            "site_name": "Site 3",
            "location": "North Ridge",
            "center_frequency_hz": 102700000,
            "sample_rate_hz": 250000,
            "gain_db": 30,
            "antenna": "Log Periodic",
            "rf_frontend": "E320",
            "reference": "GPSDO",
            "notes": "Primary monitoring site",
            "enabled": True,
        }, indent=2))
    for i in range(8):
        p = Path(args.local_watch_dir) / f"sigmf_20250519_1021{i:02d}_{i:04d}.sigmf-data"
        if not p.exists():
            p.write_text("example local file\n")
    for i in range(8):
        p = Path(args.remote_watch_dir) / f"sigmf_20250519_1021{i:02d}_{i:04d}.sigmf-data"
        if not p.exists():
            p.write_text("example remote file\n")
def main():
    parser = argparse.ArgumentParser(
        description="PyQt5 RF Site Control Dashboard"
    )
    parser.add_argument(
        "--local-script",
        default="./start_local.sh",
        help="Local bash command or script path",
    )
    parser.add_argument(
        "--remote-host",
        default="user@192.168.1.100",
        help="Remote SSH target, for example ubuntu@10.10.10.101",
    )
    parser.add_argument(
        "--remote-script",
        default="./start_remote.sh",
        help="Remote bash command or script path",
    )
    parser.add_argument(
        "--local-watch-dir",
        default="./local_output",
        help="Local directory to watch for new files",
    )
    parser.add_argument(
        "--remote-watch-dir",
        default="./remote_output",
        help="Directory on local machine showing remote-created files",
    )
    parser.add_argument(
        "--site2-json",
        default="./site2_config.json",
        help="Path to Site 2 JSON config file",
    )
    parser.add_argument(
        "--site3-json",
        default="./site3_config.json",
        help="Path to Site 3 JSON config file",
    )
    parser.add_argument(
        "--demo",
        action="store_true",
        help="Create example JSON files and example file icons",
    )
    args = parser.parse_args()
    if args.demo:
        create_example_files(args)
    app = QtWidgets.QApplication(sys.argv)
    app.setFont(QtGui.QFont("Segoe UI", 10))
    window = SiteDashboard(args)
    window.show()
    sys.exit(app.exec_())
if __name__ == "__main__":
    main()

