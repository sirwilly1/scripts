class CliPanel(PanelFrame):
    def __init__(self, title, subtitle, button_text, command, remote_host=None):
        super().__init__(title, subtitle)
        self.command = command
        self.remote_host = remote_host
        self.process = None
        self.button = QtWidgets.QPushButton(button_text)
        self.button.clicked.connect(self.run_command)
        self.addHeaderWidget(self.button)
        self.output = QtWidgets.QTextEdit()
        self.output.setReadOnly(True)
        self.addWidget(self.output, stretch=1)
    def run_command(self):
        if self.process and self.process.state() != QtCore.QProcess.NotRunning:
            self.append_line("[already running]")
            return
        self.process = QtCore.QProcess(self)
        if self.remote_host:
            program = "ssh"
            remote_cmd = f"bash -lc {shlex.quote(self.command)}"
            args = ["-tt", self.remote_host, remote_cmd]
            shown_cmd = f"ssh -tt {self.remote_host} {remote_cmd}"
        else:
            program = "bash"
            args = ["-lc", self.command]
            shown_cmd = self.command
        self.append_line(f"$ {shown_cmd}\n")
        self.process.readyReadStandardOutput.connect(self.read_stdout)
        self.process.readyReadStandardError.connect(self.read_stderr)
        self.process.finished.connect(self.process_finished)
        self.process.start(program, args)
    def read_stdout(self):
        data = bytes(self.process.readAllStandardOutput()).decode(errors="replace")
        self.output.moveCursor(QtGui.QTextCursor.End)
        self.output.insertPlainText(data)
        self.output.verticalScrollBar().setValue(
            self.output.verticalScrollBar().maximum()
        )
    def read_stderr(self):
        data = bytes(self.process.readAllStandardError()).decode(errors="replace")
        self.output.moveCursor(QtGui.QTextCursor.End)
        self.output.insertPlainText(data)
        self.output.verticalScrollBar().setValue(
            self.output.verticalScrollBar().maximum()
        )
    def process_finished(self, exit_code, exit_status):
        self.append_line(f"\n[finished] exit_code={exit_code}\n")
    def append_line(self, text):
        self.output.moveCursor(QtGui.QTextCursor.End)
        self.output.insertPlainText(text + "\n")
        self.output.verticalScrollBar().setValue(
            self.output.verticalScrollBar().maximum()
        )
class FileGridPanel(PanelFrame):
    def __init__(self, title, subtitle, watch_dir):
        super().__init__(title, subtitle)
        self.watch_dir = Path(watch_dir)
        self.watch_dir.mkdir(parents=True, exist_ok=True)
        self.scroll = QtWidgets.QScrollArea()
        self.scroll.setWidgetResizable(True)
        self.container = QtWidgets.QWidget()
        self.grid = QtWidgets.QGridLayout(self.container)
        self.grid.setContentsMargins(18, 18, 18, 18)
        self.grid.setSpacing(22)
        self.scroll.setWidget(self.container)
        self.addWidget(self.scroll, stretch=1)
        self.known_files = set()
        self.watcher = QtCore.QFileSystemWatcher(self)
        self.watcher.addPath(str(self.watch_dir))
        self.watcher.directoryChanged.connect(self.refresh_files)
        self.timer = QtCore.QTimer(self)
        self.timer.timeout.connect(self.refresh_files)
        self.timer.start(1000)
        self.refresh_files()
    def refresh_files(self):
        files = sorted(
            [p for p in self.watch_dir.iterdir() if p.is_file()],
            key=lambda p: p.stat().st_mtime,
        )
        current = set(str(p) for p in files)
        if current == self.known_files:
            return
        self.known_files = current
        while self.grid.count():
            item = self.grid.takeAt(0)
            widget = item.widget()
            if widget:
                widget.deleteLater()
        columns = 4
        for idx, path in enumerate(files):
            row = idx // columns
            col = idx % columns
            self.grid.addWidget(self.make_file_widget(path), row, col)
        self.grid.setRowStretch((len(files) // columns) + 1, 1)
    def make_file_widget(self, path: Path):
        box = QtWidgets.QFrame()
        box.setStyleSheet("""
            QFrame {
                background-color: transparent;
                border-radius: 8px;
            }
            QFrame:hover {
                background-color: #112334;
            }
        """)
        layout = QtWidgets.QVBoxLayout(box)
        layout.setContentsMargins(6, 6, 6, 6)
        layout.setSpacing(6)
        icon = QtWidgets.QLabel()
        pixmap = self.style().standardIcon(
            QtWidgets.QStyle.SP_FileIcon
        ).pixmap(52, 52)
        icon.setPixmap(pixmap)
        icon.setAlignment(QtCore.Qt.AlignCenter)
        name = QtWidgets.QLabel(path.name)
        name.setObjectName("fileName")
        name.setAlignment(QtCore.Qt.AlignCenter)
        name.setWordWrap(True)
        layout.addWidget(icon)
        layout.addWidget(name)
        return box
class JsonConfigPanel(PanelFrame):
    def __init__(self, title, subtitle, json_path):
        super().__init__(title, subtitle)
        self.json_path = Path(json_path)
        self.last_text = None
        self.table = QtWidgets.QTableWidget()
        self.table.setColumnCount(2)
        self.table.setHorizontalHeaderLabels(["Key", "Value"])
        self.table.horizontalHeader().setStretchLastSection(True)
        self.table.horizontalHeader().setSectionResizeMode(
            0, QtWidgets.QHeaderView.Stretch
        )
        self.table.horizontalHeader().setSectionResizeMode(
            1, QtWidgets.QHeaderView.Stretch
        )
        self.table.verticalHeader().setVisible(False)
        self.table.setEditTriggers(QtWidgets.QAbstractItemView.NoEditTriggers)
        self.table.setSelectionMode(QtWidgets.QAbstractItemView.NoSelection)
        self.table.setFocusPolicy(QtCore.Qt.NoFocus)
        self.addWidget(self.table, stretch=1)
        self.watcher = QtCore.QFileSystemWatcher(self)
        if self.json_path.exists():
            self.watcher.addPath(str(self.json_path))
        self.watcher.fileChanged.connect(self.load_json)
        self.timer = QtCore.QTimer(self)
        self.timer.timeout.connect(self.load_json)
        self.timer.start(1500)
        self.load_json()
    def load_json(self):
        if not self.json_path.exists():
            self.render_error(f"Missing JSON file: {self.json_path}")
            return
        if str(self.json_path) not in self.watcher.files():
            self.watcher.addPath(str(self.json_path))
        try:
            text = self.json_path.read_text()
            if text == self.last_text:
                return
            self.last_text = text
            data = json.loads(text)
            self.render_json(data)
        except Exception as e:
            self.render_error(str(e))
    def render_error(self, message):
        self.table.setRowCount(1)
        self.table.setItem(0, 0, QtWidgets.QTableWidgetItem("Error"))
        self.table.setItem(0, 1, QtWidgets.QTableWidgetItem(message))
    def render_json(self, data):
        flat = self.flatten_json(data)
        self.table.setRowCount(len(flat))
        for row, (key, value) in enumerate(flat.items()):
            key_item = QtWidgets.QTableWidgetItem(str(key))
            value_item = QtWidgets.QTableWidgetItem(str(value))
            key_item.setForeground(QtGui.QColor("#8db7df"))
            value_item.setForeground(QtGui.QColor("#edf6ff"))
            self.table.setItem(row, 0, key_item)
            self.table.setItem(row, 1, value_item)
        self.table.resizeRowsToContents()
    def flatten_json(self, data, prefix=""):
        result = {}
        if isinstance(data, dict):
            for k, v in data.items():
                new_key = f"{prefix}.{k}" if prefix else str(k)
                result.update(self.flatten_json(v, new_key))
        elif isinstance(data, list):
            for i, v in enumerate(data):
                new_key = f"{prefix}[{i}]"
                result.update(self.flatten_json(v, new_key))
        else:
            result[prefix] = data
        return result
