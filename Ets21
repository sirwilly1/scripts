#!/usr/bin/env python3
from gnuradio import gr, blocks, qtgui
from PyQt5 import Qt
import sip
import sys


class SDRStyleFIFOViewer(gr.top_block, Qt.QWidget):
    def __init__(self, fifo_path="/tmp/e320_iq.pipe", samp_rate=250e3, center_freq=102.7e6):
        gr.top_block.__init__(self, "E320 SDR Viewer")
        Qt.QWidget.__init__(self)

        self.fifo_path = fifo_path
        self.samp_rate = samp_rate
        self.center_freq = center_freq

        self.setWindowTitle("E320 SDR Monitor")
        self.resize(1280, 860)
        self.setMinimumSize(1000, 700)

        self._apply_app_style()
        self._build_ui()
        self._build_flowgraph()
        self._wire_blocks()

    def _apply_app_style(self):
        self.setStyleSheet("""
            QWidget {
                background: #0a1220;
                color: #d7e3f4;
                font-family: "Segoe UI", "Ubuntu", sans-serif;
                font-size: 11pt;
            }

            QFrame#TopBar {
                background: #0f1a2b;
                border: 1px solid #1e2c44;
                border-radius: 10px;
            }

            QLabel#TitleLabel {
                color: #f4f7fb;
                font-size: 15pt;
                font-weight: 700;
                padding: 2px 0px;
            }

            QLabel#SubLabel {
                color: #8ea6c9;
                font-size: 10pt;
                font-weight: 500;
            }

            QFrame#Panel {
                background: #0d1728;
                border: 1px solid #20314d;
                border-radius: 12px;
            }

            QLabel#PanelTitle {
                color: #dce8f8;
                font-size: 11pt;
                font-weight: 700;
                padding: 2px 0px 6px 0px;
            }

            QLabel#Badge {
                background: #11233b;
                color: #b9d4ff;
                border: 1px solid #28466f;
                border-radius: 8px;
                padding: 6px 10px;
                font-size: 10pt;
                font-weight: 600;
            }

            QSplitter::handle {
                background: #1a2940;
                height: 8px;
            }
        """)

    def _make_badge(self, text):
        label = Qt.QLabel(text)
        label.setObjectName("Badge")
        label.setAlignment(Qt.Qt.AlignCenter)
        return label

    def _make_panel(self, title_text, widget):
        frame = Qt.QFrame()
        frame.setObjectName("Panel")
        layout = Qt.QVBoxLayout(frame)
        layout.setContentsMargins(10, 10, 10, 10)
        layout.setSpacing(6)

        title = Qt.QLabel(title_text)
        title.setObjectName("PanelTitle")
        layout.addWidget(title)
        layout.addWidget(widget)

        return frame

    def _build_ui(self):
        root = Qt.QVBoxLayout(self)
        root.setContentsMargins(12, 12, 12, 12)
        root.setSpacing(10)

        # Top status/header bar
        topbar = Qt.QFrame()
        topbar.setObjectName("TopBar")
        top_layout = Qt.QHBoxLayout(topbar)
        top_layout.setContentsMargins(14, 12, 14, 12)
        top_layout.setSpacing(12)

        title_box = Qt.QVBoxLayout()
        title_box.setSpacing(1)

        title = Qt.QLabel("E320 SDR Monitor")
        title.setObjectName("TitleLabel")
        subtitle = Qt.QLabel("Live spectrum and waterfall from FIFO IQ stream")
        subtitle.setObjectName("SubLabel")

        title_box.addWidget(title)
        title_box.addWidget(subtitle)
        top_layout.addLayout(title_box, stretch=1)

        top_layout.addWidget(self._make_badge(f"Center  {self.center_freq / 1e6:.3f} MHz"))
        top_layout.addWidget(self._make_badge(f"Rate  {self.samp_rate / 1e3:.1f} kS/s"))
        top_layout.addWidget(self._make_badge("Input  int16 IQ FIFO"))

        root.addWidget(topbar)

        # Main splitter
        self.splitter = Qt.QSplitter(Qt.Qt.Vertical)
        root.addWidget(self.splitter, stretch=1)

    def _build_flowgraph(self):
        # Source chain
        self.src = blocks.file_source(
            itemsize=gr.sizeof_short,
            filename=self.fifo_path,
            repeat=False,
        )
        self.iq = blocks.interleaved_short_to_complex(False, False)
        self.scale = blocks.multiply_const_cc(1.0 / 32768.0)

        # Spectrum
        self.freq_sink = qtgui.freq_sink_c(
            2048,
            0,
            self.center_freq,
            self.samp_rate,
            "",
            1,
            None,
        )
        self.freq_sink.set_update_time(0.08)
        self.freq_sink.enable_grid(True)
        self.freq_sink.enable_autoscale(False)
        self.freq_sink.set_y_axis(-125, -25)
        self.freq_sink.set_fft_average(0.20)

        try:
            self.freq_sink.set_line_label(0, "RF")
            self.freq_sink.set_line_width(0, 2)
            self.freq_sink.set_line_alpha(0, 1.0)
        except Exception:
            pass

        try:
            self.freq_sink.disable_legend()
        except Exception:
            pass

        try:
            self.freq_sink.set_axis_labels("Frequency (MHz)", "Power (dBFS)")
        except Exception:
            pass

        try:
            self.freq_sink.set_trigger_mode(qtgui.TRIG_MODE_FREE, 0.0, 0, "")
        except Exception:
            pass

        # Waterfall
        self.waterfall_sink = qtgui.waterfall_sink_c(
            2048,
            0,
            self.center_freq,
            self.samp_rate,
            "",
            1,
            None,
        )
        self.waterfall_sink.set_update_time(0.05)
        self.waterfall_sink.enable_grid(False)

        # This is the key tuning for the darker SDR look.
        try:
            self.waterfall_sink.set_intensity_range(-108, -48)
        except Exception:
            pass

        try:
            self.waterfall_sink.disable_legend()
        except Exception:
            pass

        # Optional if supported by local GNU Radio build.
        # Some builds have different map IDs or no color map API.
        if hasattr(self.waterfall_sink, "set_color_map"):
            try:
                self.waterfall_sink.set_color_map(0, 4)
            except Exception:
                pass

        freq_widget = sip.wrapinstance(self.freq_sink.qwidget(), Qt.QWidget)
        waterfall_widget = sip.wrapinstance(self.waterfall_sink.qwidget(), Qt.QWidget)

        self.freq_panel = self._make_panel("Spectrum", freq_widget)
        self.waterfall_panel = self._make_panel("Waterfall", waterfall_widget)

        self.splitter.addWidget(self.freq_panel)
        self.splitter.addWidget(self.waterfall_panel)
        self.splitter.setSizes([220, 560])

    def _wire_blocks(self):
        self.connect((self.src, 0), (self.iq, 0))
        self.connect((self.iq, 0), (self.scale, 0))
        self.connect((self.scale, 0), (self.freq_sink, 0))
        self.connect((self.scale, 0), (self.waterfall_sink, 0))


def main():
    import argparse

    parser = argparse.ArgumentParser(description="SDR-style live spectrogram from E320 FIFO IQ stream")
    parser.add_argument("--fifo", default="/tmp/e320_iq.pipe", help="FIFO path")
    parser.add_argument("--samp-rate", type=float, default=250e3, help="Sample rate")
    parser.add_argument("--center-freq", type=float, default=102.7e6, help="Center frequency")
    args = parser.parse_args()

    qapp = Qt.QApplication(sys.argv)
    qapp.setStyle("Fusion")

    tb = SDRStyleFIFOViewer(
        fifo_path=args.fifo,
        samp_rate=args.samp_rate,
        center_freq=args.center_freq,
    )
    tb.start()
    tb.show()

    def quitting():
        tb.stop()
        tb.wait()

    qapp.aboutToQuit.connect(quitting)
    qapp.exec_()


if __name__ == "__main__":
    main()
