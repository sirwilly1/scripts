What to do after the rebuild finishes

Run these in the container:

export PYTHONPATH=/usr/local/lib/python3.8/site-packages
uhd_config_info --version
uhd_find_devices --args "type=e3xx,addr=192.168.10.2"
uhd_usrp_probe --args "type=e3xx,addr=192.168.10.2"

Then run the Python test from /, not /workspace:

cd /
unset PYTHONPATH
export PYTHONPATH=/usr/local/lib/python3.8/site-packages
python3 - <<'PY'
import uhd
print("uhd file:", uhd.__file__)
args = "type=e3xx,addr=192.168.10.2"
print("Creating MultiUSRP with:", args)
try:
    usrp = uhd.usrp.MultiUSRP(args)
    print("OK:", usrp.get_mboard_name(), usrp.get_rx_num_channels())
except Exception as e:
    print("FAILED:", repr(e))
PY

