            }
            QLabel#badgeValue {
                color: #edf6ff;
                font-size: 10pt;
                font-weight: 700;
            }
            QFrame#panelFrame {
                background-color: #0d1724;
                border: 1px solid #20384c;
                border-radius: 12px;
            }
            QLabel#panelTitle {
                color: #e6f2ff;
                font-size: 10pt;
                font-weight: 700;
                letter-spacing: 0.5px;
            }
            QLabel#panelSubtitle {
                color: #7893a8;
                font-size: 8.5pt;
                font-weight: 400;
            }
        """)
    def _polish_plot_widget(self, widget: Qt.QWidget):
        widget.setStyleSheet("""
            QWidget {
                background-color: #0a1320;
                border: none;
            }
        """)
    @staticmethod
    def _fmt_freq(freq_hz: float) -> str:
        if freq_hz >= 1e9:
            return f"{freq_hz/1e9:.6f} GHz"
        if freq_hz >= 1e6:
            return f"{freq_hz/1e6:.3f} MHz"
        if freq_hz >= 1e3:
            return f"{freq_hz/1e3:.3f} kHz"
        return f"{freq_hz:.0f} Hz"
    @staticmethod
    def _fmt_rate(rate: float) -> str:
        if rate >= 1e6:
            return f"{rate/1e6:.3f} MS/s"
        if rate >= 1e3:
            return f"{rate/1e3:.1f} kS/s"
        return f"{rate:.0f} S/s"
def main():
    parser = argparse.ArgumentParser(
        description="Live spectrogram from E320 FIFO IQ stream + SigMF chunk writer"
    )
    parser.add_argument("--fifo", default="/tmp/e320_iq.pipe", help="FIFO path")
    parser.add_argument("--samp-rate", type=float, default=250e3, help="Sample rate")
    parser.add_argument("--center-freq", type=float, default=102.7e6, help="Center frequency")
    parser.add_argument("--output-path", default="./sigmf_files", help="Directory for SigMF files")
    parser.add_argument("--chunk-seconds", type=int, default=5, help="Chunk duration in seconds")
    parser.add_argument("--gain-label", default="N/A", help="Display-only gain label")
    parser.add_argument("--source-label", default="FIFO / SSH / E320", help="Display-only source label")
    args = parser.parse_args()
    qapp = Qt.QApplication(sys.argv)
    app_font = QtGui.QFont("Segoe UI", 10)
    qapp.setFont(app_font)
    tb = HostFIFOSpectrogramSigMF(
        fifo_path=args.fifo,
        samp_rate=args.samp_rate,
        center_freq=args.center_freq,
        output_path=args.output_path,
        chunk_seconds=args.chunk_seconds,
        gain_label=args.gain_label,
        source_label=args.source_label,
    )
    tb.start()
    tb.show()
    def quitting():
        tb.stop()
        tb.wait()
    qapp.aboutToQuit.connect(quitting)
    qapp.exec_()
if __name__ == "__main__":
    main()

Run it like this:

python3 host_fifo_spectrogram_sigmf.py \
  --fifo /tmp/e320_iq.pipe \
  --samp-rate 250000 \
  --center-freq 102700000 \
  --output-path ./sigmf_files \
  --chunk-seconds 5 \
  --gain-label "40 dB" \
  --source-label "E320 / RX2 / SSH FIFO"

A couple of honest limitations:

* the surrounding UI will look much closer to the SDR / instrument-panel style you described
* the built-in GNU Radio waterfall colors may still not fully match the exact navy→cyan→yellow palette you want
* to fully control the waterfall palette and make it look like SDR++ / lab equipment, you would eventually want a custom-rendered waterfall widget instead of the stock qtgui.waterfall_sink_c

If you want, I can do a second pass that pushes this even further by adding a left-side status strip, stronger metadata badges, and a more “SDR console” panel layout.
