Yes. Here’s a redesigned host_fifo_spectrogram_sigmf.py that keeps your FIFO + SigMF functionality, but makes the Qt UI look much more like a serious SDR / spectrum-analyzer console.

What this version adds:

* dark RF-lab / avionics-inspired theme
* thin top status bar with metadata badges
* compact spectrum pane
* larger waterfall pane
* dark panel framing with subtle borders/radius
* better typography and hierarchy
* darker overall styling so it does not feel like a default Qt app

A note up front: GNU Radio’s built-in qtgui sinks do not expose full custom colormap control the way a fully custom renderer would. So this script can strongly improve the surrounding UI and some plot styling, but the waterfall palette itself is still partly constrained by the underlying GNU Radio widget.

#!/usr/bin/env python3
import sys
import os
import datetime
import argparse
import numpy as np
from gnuradio import gr, blocks, qtgui
from PyQt5 import Qt, QtGui
import sip
from sigmf import SigMFFile
class SigMFChunkWriter(gr.sync_block):
    """
    Saves incoming complex64 samples into SigMF chunks.
    Pass-through block: input complex64 -> output complex64
    """
    def __init__(self, sample_rate=250000, center_freq=102700000, output_path="./sigmf_files", duration_sec=5):
        gr.sync_block.__init__(
            self,
            name="SigMF Chunk Writer",
            in_sig=[np.complex64],
            out_sig=[np.complex64],
        )
        self.sample_rate = float(sample_rate)
        self.center_freq = float(center_freq)
        self.duration_sec = int(duration_sec)
        self.samples_per_chunk = int(self.sample_rate * self.duration_sec)
        self.buffer = np.array([], dtype=np.complex64)
        self.file_index = 0
        self.output_path = output_path
        os.makedirs(self.output_path, exist_ok=True)
    def work(self, input_items, output_items):
        in0 = input_items[0]
        output_items[0][:] = in0
        if len(in0) == 0:
            return 0
        self.buffer = np.concatenate((self.buffer, in0))
        while len(self.buffer) >= self.samples_per_chunk:
            chunk = self.buffer[:self.samples_per_chunk]
            self._write_chunk(chunk)
            self.buffer = self.buffer[self.samples_per_chunk:]
            self.file_index += 1
        return len(in0)
    def _write_chunk(self, data):
        timestamp = datetime.datetime.utcnow().strftime("%Y%m%dT%H%M%SZ")
        basename = f"sigmf_{timestamp}_{self.file_index:04d}"
        data_path = os.path.join(self.output_path, basename + ".sigmf-data")
        meta_path = os.path.join(self.output_path, basename + ".sigmf-meta")
        data.astype(np.complex64).tofile(data_path)
        meta = SigMFFile(
            data_file=os.path.basename(data_path),
            global_info={
                SigMFFile.DATATYPE_KEY: "cf32_le",
                SigMFFile.SAMPLE_RATE_KEY: self.sample_rate,
                SigMFFile.VERSION_KEY: "0.0.1",
            },
        )
        meta.add_capture(
            0,
            metadata={
                SigMFFile.FREQUENCY_KEY: self.center_freq,
                SigMFFile.DATETIME_KEY: timestamp,
            },
        )
        with open(meta_path, "w") as f:
            f.write(meta.dumps())
class MetadataBadge(Qt.QFrame):
    def __init__(self, label: str, value: str, accent: bool = False):
        super().__init__()
        self.setObjectName("metaBadgeAccent" if accent else "metaBadge")
        layout = Qt.QVBoxLayout(self)
        layout.setContentsMargins(10, 6, 10, 6)
        layout.setSpacing(1)
        lbl = Qt.QLabel(label)
        lbl.setObjectName("badgeLabel")
        val = Qt.QLabel(value)
        val.setObjectName("badgeValue")
        layout.addWidget(lbl)
        layout.addWidget(val)
class PanelFrame(Qt.QFrame):
    def __init__(self, title: str, subtitle: str | None = None):
        super().__init__()
        self.setObjectName("panelFrame")
        outer = Qt.QVBoxLayout(self)
        outer.setContentsMargins(10, 8, 10, 10)
        outer.setSpacing(8)
        header = Qt.QHBoxLayout()
        header.setContentsMargins(0, 0, 0, 0)
        title_lbl = Qt.QLabel(title)
        title_lbl.setObjectName("panelTitle")
        header.addWidget(title_lbl)
        header.addStretch(1)
        if subtitle:
            sub_lbl = Qt.QLabel(subtitle)
            sub_lbl.setObjectName("panelSubtitle")
            header.addWidget(sub_lbl)
        outer.addLayout(header)
        self.body_layout = Qt.QVBoxLayout()
        self.body_layout.setContentsMargins(0, 0, 0, 0)
        self.body_layout.setSpacing(0)
        outer.addLayout(self.body_layout)
    def addWidget(self, widget):
        self.body_layout.addWidget(widget)
class HostFIFOSpectrogramSigMF(gr.top_block, Qt.QWidget):
    def __init__(
        self,
        fifo_path="/tmp/e320_iq.pipe",
        samp_rate=250e3,
        center_freq=102.7e6,
        output_path="./sigmf_files",
        chunk_seconds=5,
        gain_label="N/A",
        source_label="FIFO / SSH / E320",
    ):
        gr.top_block.__init__(self, "E320 FIFO Spectrogram + SigMF")
        Qt.QWidget.__init__(self)
        self.setWindowTitle("E320 Signal Analysis Console")
        self.resize(1380, 920)
        self.fifo_path = fifo_path
        self.samp_rate = float(samp_rate)
        self.center_freq = float(center_freq)
        self.output_path = output_path
        self.chunk_seconds = int(chunk_seconds)
        self.gain_label = str(gain_label)
        self.source_label = source_label
        self._apply_theme()
        root = Qt.QVBoxLayout(self)
        root.setContentsMargins(14, 14, 14, 14)
        root.setSpacing(10)
        # Header / status bar
        header = Qt.QFrame()
        header.setObjectName("headerBar")
        header_layout = Qt.QHBoxLayout(header)
        header_layout.setContentsMargins(14, 10, 14, 10)
        header_layout.setSpacing(10)
        title_col = Qt.QVBoxLayout()
        title_col.setSpacing(1)
        app_title = Qt.QLabel("E320 SIGNAL ANALYSIS CONSOLE")
        app_title.setObjectName("appTitle")
        app_subtitle = Qt.QLabel("Live spectrum, waterfall, and rolling SigMF capture")
        app_subtitle.setObjectName("appSubtitle")
        title_col.addWidget(app_title)
        title_col.addWidget(app_subtitle)
        header_layout.addLayout(title_col, 1)
        header_layout.addWidget(MetadataBadge("Center Freq", self._fmt_freq(self.center_freq), accent=True))
        header_layout.addWidget(MetadataBadge("Sample Rate", self._fmt_rate(self.samp_rate)))
        header_layout.addWidget(MetadataBadge("Source", self.source_label))
        header_layout.addWidget(MetadataBadge("Gain", self.gain_label))
        header_layout.addWidget(MetadataBadge("Status", "LIVE", accent=True))
        root.addWidget(header)
        # Flowgraph blocks
        self.src = blocks.file_source(
            itemsize=gr.sizeof_short,
            filename=self.fifo_path,
            repeat=False,
        )
        self.iq = blocks.interleaved_short_to_complex(False, False)
        self.scale = blocks.multiply_const_cc(1.0 / 32768.0)
        self.sigmf_writer = SigMFChunkWriter(
            sample_rate=self.samp_rate,
            center_freq=self.center_freq,
            output_path=self.output_path,
            duration_sec=self.chunk_seconds,
        )
        # Frequency sink
        self.freq_sink = qtgui.freq_sink_c(
            1024,
            QtGui.QFont().Normal,
            self.center_freq,
            self.samp_rate,
            "",
            1,
            None,
        )
        self.freq_sink.set_update_time(0.08)
        self.freq_sink.enable_grid(True)
        self.freq_sink.enable_autoscale(False)
        self.freq_sink.set_y_axis(-140, 10)
        self.freq_sink.set_fft_average(0.18)
        self.freq_sink.enable_axis_labels(True)
        self.freq_sink.set_trigger_mode(qtgui.TRIG_MODE_FREE, 0.0, 0, "")
        self.freq_sink.set_line_label(0, "RF Spectrum")
        self.freq_sink.set_line_width(0, 1)
        self.freq_sink.set_line_color(0, "cyan")
        self.freq_sink.set_intensity_range(-140, 10)
        # Waterfall sink
        self.waterfall_sink = qtgui.waterfall_sink_c(
            1536,
            QtGui.QFont().Normal,
            self.center_freq,
            self.samp_rate,
            "",
            1,
            None,
        )
        self.waterfall_sink.set_update_time(0.06)
        self.waterfall_sink.enable_grid(False)
        self.waterfall_sink.enable_axis_labels(True)
        self.waterfall_sink.set_intensity_range(-115, -20)
        # GNU Radio connections
        self.connect((self.src, 0), (self.iq, 0))
        self.connect((self.iq, 0), (self.scale, 0))
        self.connect((self.scale, 0), (self.sigmf_writer, 0))
        self.connect((self.sigmf_writer, 0), (self.freq_sink, 0))
        self.connect((self.sigmf_writer, 0), (self.waterfall_sink, 0))
        # Wrap qtgui widgets
        freq_widget = sip.wrapinstance(self.freq_sink.qwidget(), Qt.QWidget)
        waterfall_widget = sip.wrapinstance(self.waterfall_sink.qwidget(), Qt.QWidget)
        self._polish_plot_widget(freq_widget)
        self._polish_plot_widget(waterfall_widget)
        # Panel layout
        spectrum_panel = PanelFrame(
            "SPECTRUM",
            f"Center {self._fmt_freq(self.center_freq)} • Span ~{self._fmt_rate(self.samp_rate)}"
        )
        spectrum_panel.addWidget(freq_widget)
        waterfall_panel = PanelFrame(
            "WATERFALL",
            f"Source {self.source_label} • SigMF chunks {self.chunk_seconds}s"
        )
        waterfall_panel.addWidget(waterfall_widget)
        root.addWidget(spectrum_panel, 2)
        root.addWidget(waterfall_panel, 5)
    def _apply_theme(self):
        self.setStyleSheet("""
            QWidget {
                background-color: #08111b;
                color: #d7e3f2;
                font-family: "Segoe UI", "Inter", "DejaVu Sans", sans-serif;
                font-size: 10pt;
            }
