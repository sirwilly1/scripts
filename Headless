Insert this between those two lines:

if args.headless:
    if getattr(args, "no_sigmf", False):
        raise SystemExit("--headless cannot be used with --no-sigmf")
    print("[headless] starting FIFO -> SigMF recorder", flush=True)
    print(f"[headless] fifo={args.fifo}", flush=True)
    print(f"[headless] sample_rate={args.samp_rate}", flush=True)
    print(f"[headless] center_freq={args.center_freq}", flush=True)
    print(f"[headless] output_path={args.output_path}", flush=True)
    print(f"[headless] chunk_seconds={args.chunk_seconds}", flush=True)
    tb = HeadlessSigMFRecorder(
        fifo_path=args.fifo,
        samp_rate=args.samp_rate,
        center_freq=args.center_freq,
        output_path=args.output_path,
        chunk_seconds=args.chunk_seconds,
    )
    try:
        tb.start()
        input("[headless] recording... press Enter to stop\n")
    except KeyboardInterrupt:
        print("\n[headless] stopping...", flush=True)
    finally:
        tb.stop()
        tb.wait()
        print("[headless] stopped", flush=True)
    return

