2) Add the new headless class

Put this after the SigMFChunkWriter class and before MetadataBadge:

class HeadlessSigMFRecorder(gr.top_block):
    def __init__(
        self,
        fifo_path="/tmp/e320_iq.pipe",
        samp_rate=250e3,
        center_freq=102.7e6,
        output_path="./sigmf_files",
        chunk_seconds=5,
    ):
        gr.top_block.__init__(self, "Headless FIFO SigMF Recorder")
        self.src = blocks.file_source(
            itemsize=gr.sizeof_short,
            filename=fifo_path,
            repeat=False,
        )
        self.iq = blocks.interleaved_short_to_complex(False, False)
        self.scale = blocks.multiply_const_cc(1.0 / 32768.0)
        self.sigmf_writer = SigMFChunkWriter(
            sample_rate=samp_rate,
            center_freq=center_freq,
            output_path=output_path,
            duration_sec=chunk_seconds,
        )
        self.connect((self.src, 0), (self.iq, 0))
        self.connect((self.iq, 0), (self.scale, 0))
        self.connect((self.scale, 0), (self.sigmf_writer, 0))

So your file order becomes:

